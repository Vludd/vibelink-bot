# ------------------ MTProto ------------------
# API_ID, API_HASH - values for these fields can be obtained from https://my.telegram.org/apps

# SESSION_NAME: str - simply the filename of the session :)
# ---------------------------------------------

# ----------------- App Config -----------------
# SEND_TO_CHANNEL_ID: str | int - field for submitting found vacancies
# examples: @mychannel, 1234567890
# if not specified - messages will be sent to favorite messages

# PRIVATE_CHANNEL: True | False - field that confirms that the specified channel is private and not public
# if the channel is private, '-100' will be added to its ID and converted to an integer

# DEMO_MODE: True | False - field that enables demo mode
# ----------------------------------------------


# Telegram
BOT_TOKEN=123456:AAExampleTokenFromBotFather
ADMIN_IDS=[123456789]

# Database (Postgres, async driver)
DATABASE_URL=postgresql+asyncpg://vibelink:vibelink@localhost:5432/vibelink
DB_ECHO=false

# Redis (FSM storage + throttling middleware)
REDIS_URL=redis://localhost:6379/0

# Throttling
THROTTLE_RATE_LIMIT=0.5

# Misc
LOG_LEVEL=INFO
